# GPS Reference Module — service configuration
# Copy to .env or set these as environment variables / systemd overrides.
# All values below are defaults; uncomment and edit to override.

# ── Serial ────────────────────────────────────────────────────────────────────
# GPS_SERIAL_PORT=/dev/ttyUSB0
# GPS_BAUD_RATE=115200
# GPS_SERIAL_MAX_LINE_BYTES=4096
# GPS_STATE_STALE_SECONDS=3

# ── Storage ───────────────────────────────────────────────────────────────────
# GPS_DB_PATH=/var/lib/gps-reference/data.db
# GPS_MAX_DB_BYTES=4294967296          # 4 GB

# ── HTTP server ───────────────────────────────────────────────────────────────
# GPS_HTTP_HOST=0.0.0.0
# GPS_HTTP_PORT=8000

# ── CORS — comma-separated origins, or "*" to allow all ──────────────────────
# GPS_CORS_ORIGINS=*

# ── Authentication — Bearer token for write endpoints (POST /api/upload) ─────
# GPS_API_KEY=

# ── Cloud upload — POST target for /api/upload ────────────────────────────────
# GPS_CLOUD_WEBHOOK=https://your-endpoint/ingest
